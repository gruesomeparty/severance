{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/gruesomeparty/severance/schemas/vendor/marketplace.schema.json",
  "title": "Claude Code marketplace.json (vendored minimal)",
  "description": "Structural mirror of the marketplace catalog format. Verified 2026-07-03 (docs/upstream-snapshots/plugin-marketplaces.md).",
  "type": "object",
  "required": ["name", "owner", "plugins"],
  "properties": {
    "name": { "type": "string" },
    "owner": {
      "type": ["object", "string"],
      "properties": {
        "name": { "type": "string" },
        "url": { "type": "string" }
      }
    },
    "metadata": { "type": "object" },
    "plugins": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "source"],
        "properties": {
          "name": { "type": "string" },
          "source": { "type": ["string", "object"] },
          "description": { "type": "string" },
          "version": { "type": "string" },
          "license": { "type": "string" },
          "author": { "type": ["object", "string"] }
        }
      }
    }
  }
}
